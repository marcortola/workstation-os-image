#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=scripts/lib/dotfiles.sh
source "$repo_root/scripts/lib/dotfiles.sh"

manifest="$repo_root/config/dotfiles.manifest"
dest="$repo_root/system_files/usr/share/zirconium/zdots"
backup_root="$repo_root/config/jetbrains-settings"

copy_default() {
    local source=$1 target=$2
    install -D -m 0644 "$source" "$dest/$target"
}

while IFS='|' read -r kind live_path source_path pattern; do
    [[ -z $kind || $kind == \#* ]] && continue
    case "$kind" in
        copy)
            copy_default "$HOME/$live_path" "$source_path"
            ;;
        directory|tree)
            live_dir="$HOME/$live_path"
            max_depth=()
            [[ $kind == directory ]] && max_depth=(-maxdepth 1)
            while IFS= read -r -d '' source; do
                relative=${source#"$live_dir/"}
                target="$(workstation_seed_path "$dest" "$source_path" "$relative")"
                install -D -m 0644 "$source" "$target"
            done < <(find "$live_dir" "${max_depth[@]}" -type f \
                -name "$pattern" -print0 | sort -z)
            ;;
        jetbrains-app)
            # Capture only the product-specific remainder; the shared canonical
            # under _shared/ is maintained deliberately by promote-jetbrains-shared.
            live_dir="$(workstation_jetbrains_newest_dir "$live_path")"
            [[ -n $live_dir ]] || {
                echo "JetBrains product not installed, skipping: $live_path" >&2
                continue
            }
            product_dir="$backup_root/$source_path"
            while IFS= read -r entry; do
                # Refresh each captured entry in place; the per-product plugins.list
                # is a vendored artifact (not an allow-list entry) and is preserved.
                rm -rf -- "${product_dir:?}/$entry"
                entry_src="$live_dir/$entry"
                if [[ -d $entry_src ]]; then
                    while IFS= read -r -d '' file; do
                        relative=${file#"$live_dir/"}
                        install -D -m 0644 "$file" "$product_dir/$relative"
                    done < <(find "$entry_src" -type f -print0 | sort -z)
                elif [[ -f $entry_src ]]; then
                    install -D -m 0644 "$entry_src" "$product_dir/$entry"
                fi
            done < <(workstation_jetbrains_product_allowlist)
            ;;
        template)
            ;;
        *)
            echo "Unknown manifest kind: $kind" >&2
            exit 2
            ;;
    esac
done < "$manifest"

echo "Synced manifest-listed create-only defaults. Reviewed templates were left unchanged."
