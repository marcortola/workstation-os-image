#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

git diff --check

mapfile -t shell_files < <(
    find scripts system_files/usr/bin system_files/usr/libexec -type f \
        \( -perm /111 -o -name '*.sh' \) -print | sort
    find system_files/usr/share/zirconium/zdots -type f \
        -name 'create_executable_*' -print | sort
)
bash -n "${shell_files[@]}"
shellcheck "${shell_files[@]}"
just --fmt --check
just --list >/dev/null
[[ $(< CLAUDE.md) == '@AGENTS.md' ]]
(( $(wc -l < AGENTS.md) <= 200 ))

scripts/validate-dms-overlay
jq -n -e \
    --slurpfile defaults <(scripts/dms-settings-defaults) \
    --rawfile denied config/dms-settings-denylist '
    ($denied | split("\n")
      | map(sub("[[:space:]]*#.*$"; "") | select(length > 0))) as $keys
    | $keys | all(. as $key | $defaults[0] | has($key))
' >/dev/null

scripts/test-dms-settings

fish --no-execute \
    system_files/usr/share/zirconium/zdots/dot_config/fish/create_config.fish \
    system_files/usr/share/zirconium/zdots/dot_config/fish/conf.d/*.fish \
    system_files/usr/share/zirconium/zdots/dot_config/fish/functions/*.fish

scripts/validate-manifest
scripts/validate-jetbrains-settings

tmp="$(mktemp -d)"
trap 'rm -rf -- "$tmp"' EXIT

# Git reads the XDG global config before ~/.gitconfig, so a create-only
# identity seed coexists with credential helpers and lets explicit user
# identity overrides in ~/.gitconfig continue to win.
git_home="$tmp/git-home"
install -D -m 0644 \
    system_files/usr/share/zirconium/zdots/dot_config/git/create_config \
    "$git_home/.config/git/config"
git config --file "$git_home/.gitconfig" credential.helper store
[[ $(
    HOME="$git_home" XDG_CONFIG_HOME="$git_home/.config" \
        GIT_CONFIG_NOSYSTEM=1 git -C "$git_home" config user.name
) == marcortola ]]
[[ $(
    HOME="$git_home" XDG_CONFIG_HOME="$git_home/.config" \
        GIT_CONFIG_NOSYSTEM=1 git -C "$git_home" config user.email
) == 15958009+marcortola@users.noreply.github.com ]]
[[ $(
    HOME="$git_home" XDG_CONFIG_HOME="$git_home/.config" \
        GIT_CONFIG_NOSYSTEM=1 git -C "$git_home" config credential.helper
) == store ]]
git config --file "$git_home/.gitconfig" user.name "Local Override"
[[ $(
    HOME="$git_home" XDG_CONFIG_HOME="$git_home/.config" \
        GIT_CONFIG_NOSYSTEM=1 git -C "$git_home" config user.name
) == "Local Override" ]]

scripts/audit-workstation
foot --check-config -c "$HOME/.config/foot/foot.ini"

cp -a /usr/share/zirconium/zdots/. "$tmp/"
cp -a system_files/usr/share/zirconium/zdots/. "$tmp/"
chezmoi managed -S "$tmp" > "$tmp/managed"

for target in \
    .config/foot/foot.ini \
    .config/foot/workstation.ini \
    .config/DankMaterialShell/themes/tokyoNightDark/theme.json \
    .config/git/config \
    .config/niri/config.kdl \
    .config/niri/local.kdl \
    .config/homebrew/Brewfile; do
    grep -Fqx "$target" "$tmp/managed"
done

echo "Repository and local workstation validation passed."
