#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=scripts/lib/dotfiles.sh
source "$repo_root/scripts/lib/dotfiles.sh"

manifest="$repo_root/config/dotfiles.manifest"
backup_root="$repo_root/config/jetbrains-settings"
status=0

[[ -d $backup_root ]] || {
    echo "No JetBrains settings captured; nothing to validate."
    exit 0
}

mapfile -t products < <(awk -F'|' '$1 == "jetbrains-app" { print $3 }' "$manifest")
mapfile -t shared_allow < <(workstation_jetbrains_shared_allowlist)
mapfile -t product_allow < <(workstation_jetbrains_product_allowlist)
mapfile -t deny < <(workstation_jetbrains_denylist)
mapfile -t vendored < <(workstation_jetbrains_vendored)

declared_product() {
    local candidate=$1 product
    for product in "${products[@]}"; do
        [[ $candidate == "$product" ]] && return 0
    done
    return 1
}

# A subpath is allowed if it equals or lives under an allow-list entry. The two
# buckets are disjoint by design, so this doubles as the double-ownership lint:
# a shared file dropped into a product dir (or a product file in _shared/) fails.
path_allowed() {
    local subpath=$1
    shift
    local entry
    for entry in "$@"; do
        [[ $subpath == "$entry" || $subpath == "$entry"/* ]] && return 0
    done
    return 1
}

while IFS= read -r -d '' file; do
    relative=${file#"$backup_root/"}
    bucket=${relative%%/*}
    subpath=${relative#*/}

    leaf=${subpath##*/}
    denied=false
    for pattern in "${deny[@]}"; do
        # shellcheck disable=SC2053
        if [[ $leaf == $pattern || "/$subpath/" == *"/$pattern/"* ]]; then
            denied=true
            break
        fi
    done
    if [[ $denied == true ]]; then
        echo "Secret or runtime JetBrains file must not be captured: $relative" >&2
        status=1
        continue
    fi

    if [[ $bucket == _shared ]]; then
        if ! path_allowed "$subpath" "${shared_allow[@]}" \
            && ! path_allowed "$subpath" "${vendored[@]}"; then
            echo "Unexpected file in _shared/ (not shared config or vendored): $relative" >&2
            status=1
        fi
    elif declared_product "$bucket"; then
        if [[ $subpath != plugins.list ]] \
            && ! path_allowed "$subpath" "${product_allow[@]}"; then
            echo "Shared or non-allow-listed file in product dir (promote to _shared/?): $relative" >&2
            status=1
        fi
    else
        echo "Undeclared JetBrains bucket in backup tree: $bucket" >&2
        status=1
    fi
done < <(find "$backup_root" -type f -print0 | sort -z)

# Lint every plugins.list (shared + per-product): well-formed IDs, no duplicates.
while IFS= read -r -d '' plist; do
    rel=${plist#"$backup_root/"}
    mapfile -t plugin_ids < <(workstation_jetbrains_plugins "$plist")
    for id in "${plugin_ids[@]:-}"; do
        [[ -z $id ]] && continue
        [[ $id =~ ^[A-Za-z0-9._-]+$ ]] || {
            echo "Malformed plugin ID in $rel: $id" >&2
            status=1
        }
    done
    dupes="$(printf '%s\n' "${plugin_ids[@]:-}" | sort | uniq -d | grep -v '^$' || true)"
    [[ -z $dupes ]] || { echo "Duplicate plugin IDs in $rel: $dupes" >&2; status=1; }
done < <(find "$backup_root" -name plugins.list -print0)

# The shared keymap's CamelCase binding requires CamelCase in the shared list.
shared_plugins="$backup_root/_shared/plugins.list"
keymap="$backup_root/_shared/keymaps/custom.xml"
if [[ -f $shared_plugins && -f $keymap ]] && grep -qi 'CamelCasePlugin' "$keymap"; then
    workstation_jetbrains_plugins "$shared_plugins" | grep -qiFx 'de.netnexus.camelcaseplugin' || {
        echo "Shared keymap binds CamelCase but _shared/plugins.list omits de.netnexus.camelcaseplugin" >&2
        status=1
    }
fi

if (( status == 0 )); then
    echo "JetBrains settings split cleanly (shared + product), secret-free; plugin list valid."
fi
exit "$status"
