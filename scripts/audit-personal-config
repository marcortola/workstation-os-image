#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=scripts/lib/dotfiles.sh
source "$repo_root/scripts/lib/dotfiles.sh"

manifest="$repo_root/config/dotfiles.manifest"
source_root="$repo_root/system_files/usr/share/zirconium/zdots"
config_file="${XDG_CONFIG_HOME:-$HOME/.config}/zirconium/chezmoi/chezmoi.toml"
status=0
tmp="$(mktemp -d)"
trap 'rm -rf -- "$tmp"' EXIT

report_difference() {
    local state=$1 path=$2
    printf '  %-18s %s\n' "$state" "$path"
    status=1
}

compare_file() {
    local live=$1 seed=$2 display=$3
    if [[ ! -f $live ]]; then
        report_difference "missing-live" "$display"
    elif [[ ! -f $seed ]]; then
        report_difference "uncaptured" "$display"
    elif ! cmp -s "$live" "$seed"; then
        report_difference "modified" "$display"
    fi
}

echo "Personal configuration drift:"
while IFS='|' read -r kind live_path source_path pattern; do
    [[ -z $kind || $kind == \#* ]] && continue
    case "$kind" in
        copy)
            compare_file "$HOME/$live_path" "$source_root/$source_path" "$live_path"
            ;;
        template)
            rendered="$tmp/${source_path//\//_}"
            chezmoi execute-template --config "$config_file" \
                < "$source_root/$source_path" > "$rendered"
            compare_file "$HOME/$live_path" "$rendered" "$live_path"
            ;;
        directory|tree)
            live_dir="$HOME/$live_path"
            seed_dir="$source_root/$source_path"
            max_depth=()
            [[ $kind == directory ]] && max_depth=(-maxdepth 1)

            if [[ ! -d $live_dir ]]; then
                report_difference "missing-live" "$live_path/"
                continue
            fi

            while IFS= read -r -d '' live; do
                relative=${live#"$live_dir/"}
                seed="$(workstation_seed_path "$source_root" "$source_path" "$relative")"
                compare_file "$live" "$seed" "$live_path/$relative"
            done < <(find "$live_dir" "${max_depth[@]}" -type f \
                -name "$pattern" -print0 | sort -z)

            if [[ -d $seed_dir ]]; then
                while IFS= read -r -d '' seed; do
                    relative=${seed#"$seed_dir/"}
                    live_relative="$(workstation_live_relative "$relative")"
                    [[ -f $live_dir/$live_relative ]] || \
                        report_difference "removed-live" "$live_path/$live_relative"
                done < <(find "$seed_dir" "${max_depth[@]}" -type f \
                    -name 'create_*' -print0 | sort -z)
            fi
            ;;
        jetbrains-app)
            live_dir="$(workstation_jetbrains_newest_dir "$live_path")"
            product_dir="$repo_root/config/jetbrains-settings/$source_path"
            if [[ -z $live_dir ]]; then
                [[ -d $product_dir ]] && \
                    report_difference "missing-live" "$live_path"
                continue
            fi
            while IFS= read -r entry; do
                entry_src="$live_dir/$entry"
                if [[ -d $entry_src ]]; then
                    while IFS= read -r -d '' live; do
                        relative=${live#"$live_dir/"}
                        compare_file "$live" "$product_dir/$relative" \
                            "$source_path/$relative"
                    done < <(find "$entry_src" -type f -print0 | sort -z)
                elif [[ -f $entry_src ]]; then
                    compare_file "$entry_src" "$product_dir/$entry" \
                        "$source_path/$entry"
                fi
            done < <(workstation_jetbrains_product_allowlist)

            if [[ -d $product_dir ]]; then
                while IFS= read -r -d '' seed; do
                    relative=${seed#"$product_dir/"}
                    [[ -f $live_dir/$relative ]] || \
                        report_difference "removed-live" "$source_path/$relative"
                done < <(find "$product_dir" -type f -print0 | sort -z)
            fi
            ;;
        *)
            echo "Unknown manifest kind: $kind" >&2
            exit 2
            ;;
    esac
done < "$manifest"

# Shared JetBrains canonical: compare _shared/ against the canonical product
# (the first jetbrains-app entry), which promote-jetbrains-shared captures from.
shared_dir="$repo_root/config/jetbrains-settings/_shared"
canonical_live="$(awk -F'|' '$1 == "jetbrains-app" { print $2; exit }' "$manifest")"
if [[ -d $shared_dir && -n $canonical_live ]]; then
    canonical_dir="$(workstation_jetbrains_newest_dir "$canonical_live")"
    if [[ -n $canonical_dir ]]; then
        while IFS= read -r entry; do
            entry_src="$canonical_dir/$entry"
            if [[ -d $entry_src ]]; then
                while IFS= read -r -d '' live; do
                    relative=${live#"$canonical_dir/"}
                    compare_file "$live" "$shared_dir/$relative" "_shared/$relative"
                done < <(find "$entry_src" -type f -print0 | sort -z)
            elif [[ -f $entry_src ]]; then
                compare_file "$entry_src" "$shared_dir/$entry" "_shared/$entry"
            fi
        done < <(workstation_jetbrains_shared_allowlist)

        declare -A jb_vendored=()
        while IFS= read -r vendored_entry; do
            jb_vendored["$vendored_entry"]=1
        done < <(workstation_jetbrains_vendored)
        while IFS= read -r -d '' seed; do
            relative=${seed#"$shared_dir/"}
            # Vendored artifacts (colour schemes, plugins.list) are never in a live
            # IDE, so they are not drift.
            [[ -n ${jb_vendored[$relative]:-} ]] && continue
            [[ -f $canonical_dir/$relative ]] || \
                report_difference "removed-live" "_shared/$relative"
        done < <(find "$shared_dir" -type f -print0 | sort -z)
    fi
fi

if (( status == 0 )); then
    echo "  all manifest-listed files match their repository seeds"
fi
exit "$status"
