#!/usr/bin/env bash
# worktree-init — make git-worktree file propagation work in a repository:
#   1. install the post-checkout hook into .git/hooks so worktrees created by
#      the JetBrains IDE (or any raw `git worktree add`) copy their untracked
#      files, and
#   2. drop a starter .worktreeinclude when the repo has none, so all four
#      creation paths (workmux, Claude Code, the hook, the IDE External Tool)
#      have an inventory to read.
#
# init.templateDir already seeds the hook into freshly cloned repos; this is the
# retrofit for repos that already exist, and the bulk bootstrap for every repo
# under the projects root.
#
# Usage:
#   scripts/worktree-init                 # the current repo (cwd)
#   scripts/worktree-init PATH [PATH...]  # specific repos
#   scripts/worktree-init --all           # every repo under WORKSTATION_PROJECTS_ROOT
#
# Idempotent and non-destructive: it never overwrites an existing
# .worktreeinclude, and never replaces an unmanaged or locally modified hook.
set -uo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
hook_seed="$repo_root/system_files/usr/share/zirconium/zdots/dot_config/git/template/hooks/create_executable_post-checkout"
hook_live="${XDG_CONFIG_HOME:-$HOME/.config}/git/template/hooks/post-checkout"
projects_root="${WORKSTATION_PROJECTS_ROOT:-$HOME/projects}"
managed_marker="# workstation-worktree-init: managed post-checkout hook v1"

if [[ -r $hook_seed ]]; then
    hook_src="$hook_seed"
elif [[ -r $hook_live ]]; then
    hook_src="$hook_live"
else
    echo "worktree-init: cannot find the post-checkout hook source" >&2
    exit 1
fi

install_hook() {
    local repo="$1" common dest
    if ! common="$(git -C "$repo" rev-parse --git-common-dir 2>/dev/null)"; then
        echo "  hook: failed to resolve the common Git directory" >&2
        return 1
    fi
    case "$common" in
        /*) : ;;
        *) common="$repo/$common" ;;
    esac
    dest="$common/hooks/post-checkout"
    if [[ -e $dest ]]; then
        if cmp -s "$hook_src" "$dest"; then
            echo "  hook: current"
            return 0
        fi
        if grep -Fqx "$managed_marker" "$dest" 2>/dev/null; then
            echo "  hook: skip (managed hook has local changes)"
            return 0
        fi
        echo "  hook: skip (a different post-checkout hook is already installed)"
        return 0
    fi
    if ! mkdir -p "$common/hooks"; then
        echo "  hook: failed to create $common/hooks" >&2
        return 1
    fi
    if ! install -m 0755 "$hook_src" "$dest"; then
        echo "  hook: failed to install $dest" >&2
        return 1
    fi
    echo "  hook: installed"
}

generate_worktreeinclude() {
    local repo="$1" file="$1/.worktreeinclude"
    if [[ -e $file ]]; then
        echo "  wti:  skip (already present)"
        return 0
    fi
    if {
        echo "# Untracked files to copy into new git worktrees (gitignore syntax)."
        echo "# Only files git IGNORES and that match here are copied; tracked files"
        echo "# never are. Read by Claude Code, workmux, the post-checkout hook, and the"
        echo "# JetBrains 'Sync worktree files' External Tool. Commit to share with the"
        echo "# team. node_modules/vendor/.venv belong in a per-project install step, not"
        echo "# here — copying them per worktree is the wrong tool."
        echo
        echo ".env"
        echo ".env.local"
        echo ".env.*.local"
        echo ".idea/"
        echo ".vscode/"
        echo ".claude/settings.local.json"
        if compgen -G "$repo/*.tf" >/dev/null 2>&1 || [[ -d $repo/terraform ]]; then
            echo "*.tfvars"
            echo "*.tfvars.json"
        fi
    } >"$file"; then
        echo "  wti:  generated"
        return 0
    fi
    echo "  wti:  failed to generate $file" >&2
    return 1
}

primary_worktree() {
    local repo="$1" record
    # The first porcelain record is Git's primary/source worktree. Use NUL
    # delimiters so spaces and other quoted path characters remain literal.
    if ! IFS= read -r -d '' record < <(
        git -C "$repo" worktree list --porcelain -z 2>/dev/null
    ); then
        echo "worktree-init: cannot resolve the primary worktree for $repo" >&2
        return 1
    fi
    if [[ $record != 'worktree '* ]]; then
        echo "worktree-init: invalid worktree metadata for $repo" >&2
        return 1
    fi
    printf '%s\n' "${record#worktree }"
}

process() {
    local repo="$1" primary status=0
    if ! git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "skip (not a git work tree): $repo"
        return 0
    fi
    if ! repo="$(git -C "$repo" rev-parse --show-toplevel)"; then
        echo "worktree-init: cannot resolve the worktree root for $repo" >&2
        return 1
    fi
    primary="$(primary_worktree "$repo")" || return 1
    echo "$primary"
    install_hook "$primary" || status=1
    generate_worktreeinclude "$primary" || status=1
    return "$status"
}

targets=()
if [[ ${1:-} == --all ]]; then
    while IFS= read -r gitdir; do
        targets+=("${gitdir%/.git}")
    done < <(find "$projects_root" -maxdepth 4 -type d -name .git \
        -not -path '*/node_modules/*' -not -path '*__worktrees*' \
        -not -path '*/vendor/*' 2>/dev/null | sort)
elif [[ $# -gt 0 ]]; then
    targets=("$@")
else
    targets=(".")
fi

if [[ ${#targets[@]} -eq 0 ]]; then
    echo "worktree-init: no git repositories found under $projects_root" >&2
    exit 0
fi

status=0
for repo in "${targets[@]}"; do
    process "$repo" || status=1
done
exit "$status"
