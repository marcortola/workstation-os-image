#!/usr/bin/env bash
set -uo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source_dir=/usr/share/zirconium/zdots
config_file="${XDG_CONFIG_HOME:-$HOME/.config}/zirconium/chezmoi/chezmoi.toml"
strict=false
show_details=false
status=0

for argument in "$@"; do
    case "$argument" in
        --strict) strict=true ;;
        --diff) show_details=true ;;
        *)
            echo "Usage: scripts/audit-dotfiles [--strict] [--diff]" >&2
            exit 2
            ;;
    esac
done

for command in chezmoi niri; do
    command -v "$command" >/dev/null || {
        echo "Missing required command: $command" >&2
        exit 2
    }
done

[[ -d $source_dir && -f $config_file ]] || {
    echo "Zirconium chezmoi source or configuration is missing." >&2
    exit 2
}

"$repo_root/scripts/audit-personal-config" || {
    personal_status=$?
    if (( personal_status == 2 )); then
        status=2
    else
        status=1
    fi
}

printf '\nZirconium-managed configuration drift:\n'

show_diff() {
    local label=$1 severity=$2 output
    shift 2
    if ! output="$(chezmoi diff --no-pager --color=false \
        -S "$source_dir" --config "$config_file" "$@" 2>&1)"; then
        printf '\n%s comparison failed:\n%s\n' "$label" "$output" >&2
        status=2
        return
    fi
    if [[ -n $output ]]; then
        printf '%s differs from the installed Zirconium defaults.\n' "$label"
        if [[ $show_details == true ]]; then
            printf '%s\n' "$output"
        else
            echo "  Run 'just audit-diff' for the complete diff."
        fi
        [[ $severity == critical || $strict == true ]] && status=1
    else
        printf '%s matches the installed Zirconium defaults.\n' "$label"
    fi
}

show_diff "Managed Niri scaffolding" critical \
    "$HOME/.config/niri/config.kdl" "$HOME/.config/niri/dms.kdl"
show_diff "DMS-generated Niri fragments" informational \
    "$HOME/.config/niri/dms/binds.kdl" "$HOME/.config/niri/dms/colors.kdl"
show_diff "DMS user preferences" informational \
    "$HOME/.config/DankMaterialShell/settings.json" \
    "$HOME/.config/DankMaterialShell/clsettings.json"

printf '\nIntentional Niri overrides:\n'
found=false
for override in /etc/niri/local.kdl "$HOME/.config/niri/local.kdl"; do
    if [[ -f $override ]]; then
        found=true
        printf '  %s  %s\n' "$(sha256sum "$override" | cut -d' ' -f1)" "$override"
    fi
done
[[ $found == true ]] || echo "  none"

printf '\nEffective Niri validation:\n'
if niri validate -c "$HOME/.config/niri/config.kdl"; then
    echo "Niri configuration is valid."
else
    status=1
fi
exit "$status"
