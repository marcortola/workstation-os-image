#!/usr/bin/env bash
set -euo pipefail

getent passwd | while IFS=: read -r name _ uid _ _ home shell; do
    if (( uid < 1000 || uid >= 60000 )); then
        continue
    fi

    case "$home" in
        /home/*|/var/home/*) ;;
        *) continue ;;
    esac

    case "$shell" in
        */false|*/nologin) continue ;;
    esac

    usermod -aG docker "$name"
done
