#!/usr/bin/env bash
set -euo pipefail

state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
brew=/home/linuxbrew/.linuxbrew/bin/brew
jq=/home/linuxbrew/.linuxbrew/bin/jq
brewfile="${XDG_CONFIG_HOME:-$HOME/.config}/homebrew/Brewfile"
marker="$state_home/workstation-os-image/bootstrap-complete"
repo="$HOME/projects/personal/workstation-os-image"

# Pinned Homebrew/install commit so the bootstrap never executes whatever
# HEAD serves at login time.
homebrew_installer_commit=c7952e40b7957268f61643152f4db725379b292e

mkdir -p "$(dirname "$marker")" "$HOME/.local/bin" "$HOME/.local/opt" \
    "$(dirname "$repo")"

workdir="$(mktemp -d)"
trap 'rm -rf -- "$workdir"' EXIT

if [[ ! -e $repo ]]; then
    git clone https://github.com/marcortola/workstation-os-image.git "$repo"
elif [[ ! -d $repo/.git ]]; then
    echo "$repo exists but is not a Git checkout." >&2
    exit 1
fi

if [[ ! -x $brew ]]; then
    curl -fsSL --retry 3 -o "$workdir/homebrew-install.sh" \
        "https://raw.githubusercontent.com/Homebrew/install/$homebrew_installer_commit/install.sh"
    NONINTERACTIVE=1 /bin/bash "$workdir/homebrew-install.sh"
fi

[[ -f $brewfile ]] || {
    echo "Waiting for Zirconium to create $brewfile" >&2
    exit 1
}

# Homebrew requires explicit trust before loading third-party tap formulae.
# Scope this to the OpenCode formula recommended by its upstream project.
"$brew" trust --formula anomalyco/tap/opencode
"$brew" bundle install --file "$brewfile"

# JetBrains does not publish a Linux Homebrew cask. Install Toolbox entirely
# below the home directory from its official release API, verifying the
# download-CDN tarball against the checksum served by the release API host.
toolbox_release="$(curl -fsSL \
    'https://data.services.jetbrains.com/products/releases?code=TBA&latest=true&type=release')"
toolbox_url="$("$jq" -er '.TBA[0].downloads.linux.link' <<< "$toolbox_release")"
toolbox_checksum_url="$("$jq" -er '.TBA[0].downloads.linux.checksumLink' \
    <<< "$toolbox_release")"

toolbox_archive="${toolbox_url##*/}"
curl -fL --retry 3 "$toolbox_url" -o "$workdir/$toolbox_archive"
curl -fL --retry 3 "$toolbox_checksum_url" -o "$workdir/$toolbox_archive.sha256"
(cd "$workdir" && sha256sum -c "$toolbox_archive.sha256")
tar -xzf "$workdir/$toolbox_archive" -C "$HOME/.local/opt"
toolbox_bin="$(find "$HOME/.local/opt" -path '*/bin/jetbrains-toolbox' \
    -type f | sort | tail -n 1)"
[[ -n $toolbox_bin ]]
ln -sfn "$toolbox_bin" "$HOME/.local/bin/jetbrains-toolbox"

touch "$marker"
echo "Workstation user bootstrap complete."
