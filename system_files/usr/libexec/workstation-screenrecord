#!/bin/sh
# Toggle screen recording with wf-recorder.
# First press: select a region with slurp and start recording.
# Second press: stop recording (SIGINT lets wf-recorder finalize the file).
set -eu

if pgrep -x wf-recorder >/dev/null 2>&1; then
    pkill --signal SIGINT -x wf-recorder
    notify-send --app-name=screenrecord "Recording stopped"
    exit 0
fi

# xdg-user-dir answers $HOME when the videos directory is unconfigured.
dir="${HOME}/Videos"
if command -v xdg-user-dir >/dev/null 2>&1; then
    xdg_dir="$(xdg-user-dir VIDEOS)"
    [ "$xdg_dir" = "$HOME" ] || dir="$xdg_dir"
fi
mkdir -p "$dir"
file="$dir/recording-$(date +%Y%m%d-%H%M%S).mp4"
region=$(slurp) || exit 0
notify-send --app-name=screenrecord "Recording started" "Same key stops it"
wf-recorder -g "$region" -f "$file"
