#!/usr/bin/env bash
set -euo pipefail

projects_root="${WORKSTATION_PROJECTS_ROOT:-$HOME/projects}"
open_shell=false
[[ ${1:-} == --shell ]] && open_shell=true

mapfile -t projects < <(
    find "$projects_root" -mindepth 2 -maxdepth 3 \
        -type d -name .git -prune \
        -printf '%h\n' | sort
)

if (( ${#projects[@]} == 0 )); then
    echo "No Git projects found below $projects_root" >&2
    exit 1
fi

entries=()
for project in "${projects[@]}"; do
    relative=${project#"$projects_root/"}
    project_root=${relative%%/*}
    project_name=${relative#*/}
    entries+=("$project"$'\t'"$project_root / $project_name")
done

selection="$(
    printf '%s\n' "${entries[@]}" | \
        /usr/bin/fzf --layout=reverse --height=80% --border \
            --delimiter=$'\t' --with-nth=2 \
            --header='Enter: switch project · Esc: cancel' \
            --prompt='Projects > '
)" || exit 0

project=${selection%%$'\t'*}

if $open_shell; then
    cd -- "$project"
    exec /usr/bin/fish
fi

printf '%s\n' "$project"
