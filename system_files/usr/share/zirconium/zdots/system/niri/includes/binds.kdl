// Workstation fork of the Zirconium/DMS niri binds and hotkey overlay.
//
// OVERLAY ORDER (Super+/) IS NOT THIS FILE'S ORDER. niri builds it in
// `collect_actions` (src/ui/hotkey_overlay.rs), which emits:
//
//   1. A fixed, compiled block of "important" actions, ALWAYS in this order:
//        show-hotkey-overlay, quit, close-window,
//        focus-column-left, focus-column-right,
//        move-column-left, move-column-right,
//        focus-workspace-down, focus-workspace-up,
//        move-column-to-workspace-down, move-column-to-workspace-up,
//        switch-preset-column-width, maximize-column,
//        consume-or-expel-window-left, consume-or-expel-window-right,
//        toggle-window-floating, switch-focus-between-floating-and-tiling,
//        toggle-overview (a native screenshot action would follow, but this
//        config spawns instead so none appears).
//   2. Then every bind that has a custom hotkey-overlay-title WHOSE ACTION IS
//      NOT already in that block, in THIS FILE's order (dedup is by action).
//   3. Then any Mod/Super `spawn` bind, in file order (all ours are titled or
//      null, so none surface here).
//
// Two consequences drive the layout below:
//   - A custom title on a bind whose action is in the fixed block only
//     RELABELS its row; it cannot move it out of the block. So these are
//     pinned to niri's slots no matter where they sit here: Focus Column
//     Left/Right, Move Column Left/Right, Switch Workspace Up/Down, Move
//     Column to Workspace Up/Down, Switch Column Preset, Maximize Column,
//     Move Window Between Columns, Toggle Window Floating, Show Overview.
//   - Only the REMAINING custom-titled binds honour file order. They are laid
//     out here as window/column/workspace/monitor management first (so the
//     overlay continues straight out of the fixed window block), then
//     Launchers & Apps, then System & Utilities.
//
// Each directional pair collapses to one overlay row: the titled half supplies
// the label, the other half is hotkey-overlay-title=null so niri hides it (the
// +/- column-width pair works the same way). `hide-not-bound true` drops the
// unbound fixed actions — quit and switch-focus-between-floating-and-tiling,
// whose old key Mod+Shift+V is repurposed to dictation.
//
// Conflicts resolved (niri core wins; the DMS feature is dropped from the
// overlay, the key keeps working):
//   Mod+V       toggle-window-floating        (was DMS Clipboard Manager)
//   Mod+Comma   consume-window-into-column    (was DMS Settings)
//   Mod+M       maximize-column               (was DMS Task Manager; = Mod+F)
//
// Personal binds use spawn-sh with $HOME so no username is hardcoded.

hotkey-overlay {
    hide-not-bound true
}

binds {
    // ── Session ─────────────────────────────────────────────────────────
    Mod+Slash { show-hotkey-overlay; }
    Mod+Q repeat=false { close-window; }

    // ── Columns & window sizing ─────────────────────────────────────────
    Mod+R         hotkey-overlay-title="Switch Column Preset" { switch-preset-column-width; }
    Mod+M         hotkey-overlay-title="Maximize Column" { maximize-column; }
    Mod+Minus     hotkey-overlay-title="Decrease/Increase Column Width" { set-column-width "-10%"; }
    Mod+Equal     hotkey-overlay-title=null { set-column-width "+10%"; }
    Mod+C         hotkey-overlay-title="Center Column" { center-column; }
    Mod+BracketLeft  hotkey-overlay-title="Move Window Between Columns Left/Right" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title=null { consume-or-expel-window-right; }
    Mod+Comma  { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }
    Mod+V { toggle-window-floating; }
    Mod+W { toggle-column-tabbed-display; }
    Mod+Shift+F { fullscreen-window; }
    Mod+Ctrl+F  { maximize-window-to-edges; }
    Mod+Ctrl+C  { center-visible-columns; }
    Mod+Ctrl+R  { reset-window-height; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // ── Focus ───────────────────────────────────────────────────────────
    Mod+Left  hotkey-overlay-title="Focus Column Left/Right" { focus-column-left; }
    Mod+Right hotkey-overlay-title=null { focus-column-right; }
    Mod+H     { focus-column-left; }
    Mod+J     hotkey-overlay-title="Focus Window Down/Up" { focus-window-down; }
    Mod+K     hotkey-overlay-title=null { focus-window-up; }
    Mod+L     { focus-column-right; }

    Mod+Home hotkey-overlay-title="Focus First/Last Column" { focus-column-first; }
    Mod+End  hotkey-overlay-title=null { focus-column-last; }

    // ── Move ────────────────────────────────────────────────────────────
    Mod+Ctrl+Left  hotkey-overlay-title="Move Column Left/Right" { move-column-left; }
    Mod+Ctrl+Right hotkey-overlay-title=null { move-column-right; }
    Mod+Ctrl+H     { move-column-left; }
    Mod+Ctrl+J     hotkey-overlay-title="Move Window Down/Up" { move-window-down; }
    Mod+Ctrl+K     hotkey-overlay-title=null { move-window-up; }
    Mod+Ctrl+L     { move-column-right; }

    Mod+Ctrl+Home hotkey-overlay-title="Move Column to First/Last Position" { move-column-to-first; }
    Mod+Ctrl+End  hotkey-overlay-title=null { move-column-to-last; }

    // ── Workspaces ──────────────────────────────────────────────────────
    Mod+Up        hotkey-overlay-title="Switch Workspace Up/Down" { focus-workspace-up; }
    Mod+Down      hotkey-overlay-title=null { focus-workspace-down; }
    Mod+Ctrl+Up   hotkey-overlay-title="Move Column to Workspace Up/Down" { move-column-to-workspace-up; }
    Mod+Ctrl+Down hotkey-overlay-title=null { move-column-to-workspace-down; }
    Mod+Page_Down { focus-workspace-down; }
    Mod+Page_Up   { focus-workspace-up; }
    Mod+U         { focus-workspace-down; }
    Mod+I         { focus-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+U         { move-column-to-workspace-down; }
    Mod+Ctrl+I         { move-column-to-workspace-up; }

    Mod+1 hotkey-overlay-title="Switch to Workspace 1–9" { focus-workspace 1; }
    Mod+2 hotkey-overlay-title=null { focus-workspace 2; }
    Mod+3 hotkey-overlay-title=null { focus-workspace 3; }
    Mod+4 hotkey-overlay-title=null { focus-workspace 4; }
    Mod+5 hotkey-overlay-title=null { focus-workspace 5; }
    Mod+6 hotkey-overlay-title=null { focus-workspace 6; }
    Mod+7 hotkey-overlay-title=null { focus-workspace 7; }
    Mod+8 hotkey-overlay-title=null { focus-workspace 8; }
    Mod+9 hotkey-overlay-title=null { focus-workspace 9; }

    Mod+Ctrl+1 hotkey-overlay-title="Move Column to Workspace 1–9" { move-column-to-workspace 1; }
    Mod+Ctrl+2 hotkey-overlay-title=null { move-column-to-workspace 2; }
    Mod+Ctrl+3 hotkey-overlay-title=null { move-column-to-workspace 3; }
    Mod+Ctrl+4 hotkey-overlay-title=null { move-column-to-workspace 4; }
    Mod+Ctrl+5 hotkey-overlay-title=null { move-column-to-workspace 5; }
    Mod+Ctrl+6 hotkey-overlay-title=null { move-column-to-workspace 6; }
    Mod+Ctrl+7 hotkey-overlay-title=null { move-column-to-workspace 7; }
    Mod+Ctrl+8 hotkey-overlay-title=null { move-column-to-workspace 8; }
    Mod+Ctrl+9 hotkey-overlay-title=null { move-column-to-workspace 9; }

    Mod+Shift+Page_Down hotkey-overlay-title="Move Workspace Down/Up" { move-workspace-down; }
    Mod+Shift+Page_Up   hotkey-overlay-title=null { move-workspace-up; }
    Mod+Shift+U         { move-workspace-down; }
    Mod+Shift+I         { move-workspace-up; }

    // ── Monitors ────────────────────────────────────────────────────────
    Mod+Shift+Left  hotkey-overlay-title="Focus Monitor Left/Right" { focus-monitor-left; }
    Mod+Shift+Right hotkey-overlay-title=null { focus-monitor-right; }
    Mod+Shift+Down  hotkey-overlay-title="Focus Monitor Down/Up" { focus-monitor-down; }
    Mod+Shift+Up    hotkey-overlay-title=null { focus-monitor-up; }
    Mod+Shift+H     { focus-monitor-left; }
    Mod+Shift+J     { focus-monitor-down; }
    Mod+Shift+K     { focus-monitor-up; }
    Mod+Shift+L     { focus-monitor-right; }

    Mod+Shift+Ctrl+Left  hotkey-overlay-title="Move Column to Monitor Left/Right" { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Right hotkey-overlay-title=null { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+Down  hotkey-overlay-title="Move Column to Monitor Down/Up" { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    hotkey-overlay-title=null { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+H     { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J     { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K     { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L     { move-column-to-monitor-right; }

    // ── Overview (bridges into apps) ────────────────────────────────────
    Mod+O repeat=false hotkey-overlay-title="Show Overview" { toggle-overview; }

    // ── Launchers & apps ────────────────────────────────────────────────
    Mod+T hotkey-overlay-title="Open a Terminal" { spawn "xdg-terminal-exec"; }
    Mod+Space hotkey-overlay-title="Application Launcher" {
        spawn "dms" "ipc" "call" "spotlight" "toggle";
    }
    Mod+F hotkey-overlay-title="Open File Manager" { spawn "nautilus"; }
    Mod+Shift+P hotkey-overlay-title="Projects" {
        spawn-sh "foot --working-directory=$HOME --title=Projects --app-id=dev-terminal $HOME/.local/bin/workstation-dev --shell";
    }
    Mod+Shift+O hotkey-overlay-title="OpenCode" {
        spawn-sh "foot --working-directory=$HOME --title=OpenCode --app-id=opencode /home/linuxbrew/.linuxbrew/bin/opencode";
    }
    Mod+Shift+G hotkey-overlay-title="Lazygit" {
        spawn-sh "foot --working-directory=$HOME --title=Lazygit --app-id=lazygit /home/linuxbrew/.linuxbrew/bin/lazygit";
    }
    Mod+Shift+D hotkey-overlay-title="Lazydocker" {
        spawn-sh "foot --working-directory=$HOME --title=Lazydocker --app-id=lazydocker /home/linuxbrew/.linuxbrew/bin/lazydocker";
    }
    Ctrl+Alt+Delete hotkey-overlay-title="Task Manager and Activity (btop)" {
        spawn-sh "foot --working-directory=$HOME --title=Activity --app-id=btop /usr/bin/btop";
    }

    // ── System & utilities ──────────────────────────────────────────────
    Mod+N hotkey-overlay-title="Notification Center" {
        spawn "dms" "ipc" "call" "notifications" "toggle";
    }
    Mod+Shift+N hotkey-overlay-title="Notepad" {
        spawn "dms" "ipc" "call" "notepad" "toggle";
    }
    Mod+Shift+S hotkey-overlay-title="Take a Screenshot" {
        spawn "dms" "ipc" "call" "niri" "screenshot";
    }
    Mod+Print hotkey-overlay-title="Read contents of screen" { spawn "zocr" "screenshot"; }
    Mod+Shift+R hotkey-overlay-title="Start/stop screen recording" {
        spawn "/usr/libexec/workstation-screenrecord";
    }
    Mod+Shift+V hotkey-overlay-title="Start/stop dictation" {
        spawn-sh "$HOME/.local/bin/workstation-dictate";
    }
    Ctrl+Alt+Space hotkey-overlay-title="Switch Keyboard Language" {
        spawn-sh "$HOME/.local/bin/workstation-cycle-keyboard-layout";
    }

    // ── Scroll ──────────────────────────────────────────────────────────
    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // ── Media & display ─────────────────────────────────────────────────
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }
    XF86AudioPlay allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioNext allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPrev allow-when-locked=true { spawn "playerctl" "previous"; }

    XF86MonBrightnessUp   allow-when-locked=true { spawn-sh "brightnessctl --class=backlight set +10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn-sh "brightnessctl --class=backlight set 10%-"; }

    // ── Screenshots (hidden variants; visible ones are above) ───────────
    Print hotkey-overlay-title=null { spawn "dms" "ipc" "call" "niri" "screenshot"; }
    Ctrl+Print { spawn "dms" "ipc" "call" "niri" "screenshotScreen"; }
    Alt+Print { spawn "dms" "ipc" "call" "niri" "screenshotWindow"; }
    Mod+Alt+Shift+S hotkey-overlay-title=null { spawn "zocr" "screenshot"; }

    // ── Hidden from overlay (null-titled; keys still work) ───────────────
    Mod+Y hotkey-overlay-title=null { spawn "dms" "ipc" "call" "dankdash" "wallpaper"; }
    Mod+Alt+L hotkey-overlay-title=null { spawn "dms" "ipc" "call" "lock" "lock"; }

    Super+Alt+S allow-when-locked=true hotkey-overlay-title=null { spawn-sh "pkill orca || exec orca"; }
    Ctrl+Shift+Alt+Mod+L hotkey-overlay-title=null {
        spawn "xdg-open" "https://googleballs.com/";
    }

    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
}
