// Local workstation shortcuts. This file is preserved by Zirconium/chezmoi.
binds {
    Mod+Shift+G hotkey-overlay-title="Lazygit" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=Lazygit" "--app-id=lazygit" "/home/linuxbrew/.linuxbrew/bin/lazygit";
    }
    Mod+Shift+D hotkey-overlay-title="Lazydocker" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=Lazydocker" "--app-id=lazydocker" "/home/linuxbrew/.linuxbrew/bin/lazydocker";
    }
    Mod+Shift+T hotkey-overlay-title="Activity (btop)" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=Activity" "--app-id=btop" "/usr/bin/btop";
    }
    Mod+Shift+O hotkey-overlay-title="OpenCode" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=OpenCode" "--app-id=opencode" "/home/linuxbrew/.linuxbrew/bin/opencode";
    }
    Mod+Shift+V hotkey-overlay-title="Start/stop dictation" {
        spawn "{{ .chezmoi.homeDir }}/.local/bin/workstation-dictate";
    }
}
