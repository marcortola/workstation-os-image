// Local workstation shortcuts. This file is preserved by Zirconium/chezmoi.
// Mod+Ctrl+T (Open a Tmux Terminal) lives in the forked system binds.kdl so it
// appears right after "Open a Terminal" in the Super+/ overlay.
binds {
    // Vertical arrows drive workspaces instead of window-in-column focus.
    // Custom hotkey-overlay titles make niri's "Important Hotkeys" pop-up show
    // these arrows instead of the built-in Page Up/Down binds (niri shows a
    // custom-titled bind in preference to the first untitled one for an action).
    // (Window-stack nav stays on Mod+J / Mod+K; Page Up/Down still work.)
    Mod+Up        hotkey-overlay-title="Switch Workspace Up"          { focus-workspace-up; }
    Mod+Down      hotkey-overlay-title="Switch Workspace Down"        { focus-workspace-down; }
    Mod+Ctrl+Up   hotkey-overlay-title="Move Column to Workspace Up"   { move-column-to-workspace-up; }
    Mod+Ctrl+Down hotkey-overlay-title="Move Column to Workspace Down" { move-column-to-workspace-down; }

    // Switch keyboard layout (fcitx5 us/es). Takes Ctrl+Space's old job so that
    // key is free for the tmux prefix; the cycle helper drives fcitx5.
    Ctrl+Alt+Space hotkey-overlay-title="Switch Keyboard Language" {
        spawn "{{ .chezmoi.homeDir }}/.local/bin/workstation-cycle-keyboard-layout";
    }

    Mod+Shift+G hotkey-overlay-title="Lazygit" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=Lazygit" "--app-id=lazygit" "/home/linuxbrew/.linuxbrew/bin/lazygit";
    }
    Mod+Shift+D hotkey-overlay-title="Lazydocker" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=Lazydocker" "--app-id=lazydocker" "/home/linuxbrew/.linuxbrew/bin/lazydocker";
    }
    Mod+Shift+T hotkey-overlay-title="Activity (btop)" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=Activity" "--app-id=btop" "/usr/bin/btop";
    }
    Mod+Shift+O hotkey-overlay-title="OpenCode" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=OpenCode" "--app-id=opencode" "/home/linuxbrew/.linuxbrew/bin/opencode";
    }
    Mod+Shift+P hotkey-overlay-title="Projects" {
        spawn "foot" "--working-directory={{ .chezmoi.homeDir }}" "--title=Projects" "--app-id=dev-terminal" "{{ .chezmoi.homeDir }}/.local/bin/workstation-dev" "--shell";
    }
    Mod+Shift+V hotkey-overlay-title="Start/stop dictation" {
        spawn "{{ .chezmoi.homeDir }}/.local/bin/workstation-dictate";
    }
    Mod+Shift+R hotkey-overlay-title="Start/stop screen recording" {
        spawn "/usr/libexec/workstation-screenrecord";
    }
}

layout {
    // Keep an always-empty workspace above the first one, mirroring niri's
    // built-in always-empty trailing workspace. Makes Mod+Ctrl+Up land a column
    // in an existing empty workspace at the top instead of appearing to spawn
    // one, so the top edge behaves symmetrically with the bottom. (Merged with
    // niri's other layout blocks from the DMS/Zirconium includes.)
    empty-workspace-above-first
}
